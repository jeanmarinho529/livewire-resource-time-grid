{
    "name": "jeanmarinho529/livewire-resource-time-grid",
    "description": "Laravel Livewire resource time grid component (custom version)",
    "keywords": [
        "jeanmarinho529",
        "livewire-resource-time-grid"
    ],
    "homepage": "https://github.com/asantibanez/livewire-resource-time-grid",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Andrés Santibáñez",
            "email": "santibanez.andres@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.2|^8.0|^8.1|^8.2|^8.3",
        "illuminate/support": "^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0|^4.2"
    },
    "require-dev": {
        "orchestra/testbench": "^5.0|^6.0|^7.0|^8.0|^9.0|^11.0",
        "phpunit/phpunit": "^8.0|^9.0|^10.0|^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "Jeanmarinho529\\LivewireResourceTimeGrid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jeanmarinho529\\LivewireResourceTimeGrid\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jeanmarinho529\\LivewireResourceTimeGrid\\LivewireResourceTimeGridServiceProvider"
            ]
        }
    }
}
